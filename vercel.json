{
  "functions": {
    "api/sync/*.js": {
      "maxDuration": 60
    },
    "api/webhook/readai.js": {
      "maxDuration": 60
    },
    "api/knowledge/*.js": {
      "maxDuration": 60
    },
    "api/instantly/*.js": {
      "maxDuration": 60
    },
    "api/webhook/instantly.js": {
      "maxDuration": 60
    },
    "api/meetings/*.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
