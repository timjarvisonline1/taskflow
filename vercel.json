{
  "functions": {
    "api/sync/*.js": {
      "maxDuration": 300
    },
    "api/cron/*.js": {
      "maxDuration": 300
    },
    "api/webhook/readai.js": {
      "maxDuration": 60
    },
    "api/knowledge/*.js": {
      "maxDuration": 60
    },
    "api/meetings/*.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/email-tasks",
      "schedule": "*/30 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
